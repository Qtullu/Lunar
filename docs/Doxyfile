#---------------------------------------------------------------------------
# Lunar Plugin Doxygen configuration
#---------------------------------------------------------------------------

DOXYFILE_ENCODING      = UTF-8
PROJECT_NAME           = "Lunar Plugin"
PROJECT_BRIEF          = "Runtime subsystems, function libraries, widgets etc."
PROJECT_NUMBER         = "UE 5.8"
OUTPUT_DIRECTORY       = docs
OUTPUT_LANGUAGE        = English
MARKDOWN_SUPPORT       = YES
USE_MDFILE_AS_MAINPAGE =

#---------------------------------------------------------------------------
# Input
#---------------------------------------------------------------------------

INPUT                  = Source \
                         docs/mainpage.md \
                         docs/groups.dox

INPUT_ENCODING         = UTF-8
RECURSIVE              = YES

FILE_PATTERNS          = *.h \
                         *.hpp \
                         *.hh \
                         *.cpp \
                         *.cxx \
                         *.cc \
                         *.inl \
                         *.md \
                         *.dox

EXCLUDE                =
EXCLUDE_SYMLINKS       = NO

EXCLUDE_PATTERNS       = */Binaries/* \
                         */Intermediate/* \
                         */Saved/* \
                         */DerivedDataCache/* \
                         */.git/* \
                         */.vs/* \
                         */docs/html/* \
                         */docs/latex/* \
                         */docs/xml/* \
                         */docs/doxygen-awesome-css/*

EXCLUDE_SYMBOLS        =
IMAGE_PATH             = docs

#---------------------------------------------------------------------------
# Output
#---------------------------------------------------------------------------

GENERATE_HTML          = YES
GENERATE_LATEX         = NO
GENERATE_RTF           = NO
GENERATE_MAN           = NO
GENERATE_XML           = YES
GENERATE_DOCBOOK       = NO
GENERATE_AUTOGEN_DEF   = NO
GENERATE_PERLMOD       = NO

HTML_OUTPUT            = html
XML_OUTPUT             = xml
