ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = YES
SEARCH_INCLUDES        = YES
INCLUDE_PATH           = Source
INCLUDE_FILE_PATTERNS  = *.h
SKIP_FUNCTION_MACROS   = NO

PREDEFINED             = UCLASS(...)= \
                         USTRUCT(...)= \
                         UENUM(...)= \
                         UINTERFACE(...)= \
                         UDELEGATE(...)= \
                         UFUNCTION(...)= \
                         UPROPERTY(...)= \
                         UMETA(...)= \
                         GENERATED_BODY()= \
                         GENERATED_UCLASS_BODY()= \
                         GENERATED_USTRUCT_BODY()= \
                         GENERATED_INTERFACE_BODY()= \
                         GENERATED_IINTERFACE_BODY()= \
                         GENERATED_UINTERFACE_BODY()= \
                         LUNAR_API= \
                         TEXT(x)=x

EXPAND_AS_DEFINED      = UCLASS \
                         USTRUCT \
                         UENUM \
                         UINTERFACE \
                         UDELEGATE \
                         UFUNCTION \
                         UPROPERTY \
                         UMETA \
                         GENERATED_BODY \
                         GENERATED_UCLASS_BODY \
                         GENERATED_USTRUCT_BODY \
                         GENERATED_INTERFACE_BODY \
                         GENERATED_IINTERFACE_BODY \
                         GENERATED_UINTERFACE_BODY

